# ──────────────────────────────────────────────
# OptionStrategy — Environment Configuration
# Copy to .env and adjust values as needed.
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
MARKET_DB_PATH=./market_data.sqlite
# DB_TIMEOUT=10

# ── Server ────────────────────────────────────
PORT=5000
# HOST=0.0.0.0

# ── Network / Proxy ───────────────────────────
# RECOMMENDED: route all yfinance traffic through a VPN/proxy. Yahoo
# Finance is unreachable or aggressively rate-limited from many regions
# (notably mainland China). YF_PROXY is mapped to HTTP_PROXY/HTTPS_PROXY
# at startup for curl_cffi (used by yfinance). The proxy is TCP-probed
# at startup; if unreachable the app falls back to direct.
YF_PROXY=http://127.0.0.1:1087        # Clash / V2Ray HTTP (most common)
# YF_PROXY=http://127.0.0.1:7890       # Clash alternative
# YF_PROXY=socks5h://127.0.0.1:1080    # SOCKS5

# ── Scheduler ─────────────────────────────────
# Comma-separated tickers for auto-update
# AUTO_UPDATE_TICKERS=AAPL,MSFT,SPY
# Timezone for scheduler cron jobs (default: UTC)
# SCHED_TZ=America/New_York
# Daily update time (HH:MM, 24h format, default: 16:15)
# SCHED_DAILY_TIME=16:15
# Monthly correlation update day/time (default: 1st at 02:00)
# SCHED_MONTHLY_DAY=1
# SCHED_MONTHLY_TIME=02:00
